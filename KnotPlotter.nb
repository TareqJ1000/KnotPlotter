         RowBox[{"Range", "[", 
          RowBox[{"Length", "[", 
           RowBox[{"M", "[", 
            RowBox[{"[", "1", "]"}], "]"}], "]"}], "]"}], ",", 
         RowBox[{"Flatten", "@", 
          RowBox[{"{", "inds", "}"}]}]}], "]"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"M", "[", 
       RowBox[{"[", 
        RowBox[{"All", ",", "keep"}], "]"}], "]"}]}]}], "]"}]}], 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"IndexedInterpolatedKnotPlot", "[", 
    RowBox[{"M_", ",", 
     RowBox[{"Color_", ":", "Red"}], ",", 
     RowBox[{"z_", ":", "1"}], ",", 
     RowBox[{"InterpOrder_", ":", "2"}], ",", 
     RowBox[{"LeftShift_", ":", "0"}], ",", 
     RowBox[{"step_", ":", "2"}]}], "]"}], ":=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
      "A", ",", "dim", ",", "A1", ",", "Apts", ",", "f1", ",", "knot", ",", 
       "labels"}], "}"}], ",", 
     RowBox[{
      RowBox[{"A", "=", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"M", "[", 
          RowBox[{"[", "1", "]"}], "]"}], ",", 
         RowBox[{"M", "[", 
          RowBox[{"[", "2", "]"}], "]"}], ",", 
         RowBox[{"M", "[", 
          RowBox[{"[", "3", "]"}], "]"}]}], "}"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"dim", "=", 
       RowBox[{"Dimensions", "[", "A", "]"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"Apts", "=", 
       RowBox[{"Table", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{
           RowBox[{"A", "[", 
            RowBox[{"[", 
             RowBox[{"1", ",", "i"}], "]"}], "]"}], ",", 
           RowBox[{"A", "[", 
            RowBox[{"[", 
             RowBox[{"2", ",", "i"}], "]"}], "]"}], ",", 
           RowBox[{
            RowBox[{"A", "[", 
             RowBox[{"[", 
              RowBox[{"3", ",", "i"}], "]"}], "]"}], "*", "z"}]}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{"i", ",", "1", ",", 
           RowBox[{"dim", "[", 
            RowBox[{"[", "2", "]"}], "]"}]}], "}"}]}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"Apts", "=", 
       RowBox[{"RotateLeft", "[", 
        RowBox[{"Apts", ",", "LeftShift"}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"A1", "=", 
       RowBox[{"Append", "[", 
        RowBox[{"Apts", ",", 
         RowBox[{"Apts", "[", 
          RowBox[{"[", "1", "]"}], "]"}]}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"f1", "=", 
       RowBox[{"Interpolation", "[", 
        RowBox[{
         RowBox[{"Transpose", "[", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{"Range", "[", 
             RowBox[{"Length", "[", "A1", "]"}], "]"}], ",", "A1"}], "}"}], 
          "]"}], ",", 
         RowBox[{"Method", "->", "\"\<Spline\>\""}], ",", 
         RowBox[{"InterpolationOrder", "->", "InterpOrder"}]}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"knot", "=", 
       RowBox[{
        RowBox[{"ParametricPlot3D", "[", 
         RowBox[{
          RowBox[{"f1", "[", "u", "]"}], ",", 
          RowBox[{"{", 
           RowBox[{"u", ",", "1", ",", 
            RowBox[{"Length", "[", "A1", "]"}]}], "}"}], ",", 
          RowBox[{"ColorFunction", "->", 
           RowBox[{"(", 
            RowBox[{
             RowBox[{"Directive", "[", 
              RowBox[{
               RowBox[{"Opacity", "[", "1", "]"}], ",", "Color"}], "]"}], 
             "&"}], ")"}]}], ",", 
          RowBox[{"ColorFunctionScaling", "->", "False"}], ",", 
          RowBox[{"Boxed", "->", "False"}], ",", 
          RowBox[{"Axes", "->", "False"}], ",", 
          RowBox[{"Ticks", "->", "None"}], ",", 
          RowBox[{"PlotPoints", "->", "200"}], ",", 
          RowBox[{"MaxRecursion", "->", "2"}]}], "]"}], "/.", " ", 
        RowBox[{
         RowBox[{"Line", "[", 
          RowBox[{"pts_", ",", "rest___"}], "]"}], ":>", 
         RowBox[{"{", 
          RowBox[{"Color", ",", 
           RowBox[{"Tube", "[", 
            RowBox[{"pts", ",", "0.5"}], "]"}]}], "}"}]}]}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"labels", "=", 
       RowBox[{"Graphics3D", "[", 
        RowBox[{"Table", "[", 
         RowBox[{
          RowBox[{"If", "[", 
           RowBox[{
            RowBox[{
             RowBox[{"Mod", "[", 
              RowBox[{
               RowBox[{"i", "-", "1"}], ",", "step"}], "]"}], "==", "0"}], 
            ",", 
            RowBox[{"{", 
             RowBox[{"Blue", ",", 
              RowBox[{"PointSize", "[", "0.02", "]"}], ",", 
              RowBox[{"Point", "[", 
               RowBox[{"Apts", "[", 
                RowBox[{"[", "i", "]"}], "]"}], "]"}], ",", "Black", ",", 
              RowBox[{"Text", "[", 
               RowBox[{
                RowBox[{"Style", "[", 
                 RowBox[{"i", ",", "12", ",", "Bold"}], "]"}], ",", 
                RowBox[{"Apts", "[", 
                 RowBox[{"[", "i", "]"}], "]"}], ",", 
                RowBox[{"{", 
                 RowBox[{"1", ",", "1"}], "}"}]}], "]"}]}], "}"}], ",", 
            RowBox[{"{", 
             RowBox[{"Gray", ",", 
              RowBox[{"PointSize", "[", "0.01", "]"}], ",", 
              RowBox[{"Point", "[", 
               RowBox[{"Apts", "[", 
                RowBox[{"[", "i", "]"}], "]"}], "]"}]}], "}"}]}], "]"}], ",", 
          RowBox[{"{", 
           RowBox[{"i", ",", "1", ",", 
            RowBox[{"Length", "[", "Apts", "]"}]}], "}"}]}], "]"}], "]"}]}], 
      ";", "\[IndentingNewLine]", 
      RowBox[{"Show", "[", 
       RowBox[{"knot", ",", "labels", ",", 
        RowBox[{"Boxed", "->", "False"}], ",", 
        RowBox[{"Axes", "->", "False"}], ",", 
        RowBox[{"ImageSize", "->", "Large"}], ",", 
        RowBox[{"SphericalRegion", "->", "True"}]}], "]"}]}]}], "]"}]}], 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
