Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"KnotMean", "[", 
    RowBox[{"M_", ",", " ", 
     RowBox[{"z_", ":", "1"}]}], "]"}], ":=", "\[IndentingNewLine]", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"A", ",", " ", "dim", ",", " ", "A1", ",", " ", "A2"}], "}"}], 
     ",", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"A", " ", "=", " ", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"GaussianFilter", "[", 
          RowBox[{
           RowBox[{"M", "[", 
            RowBox[{"[", "1", "]"}], "]"}], ",", "5"}], "]"}], ",", 
         RowBox[{"GaussianFilter", "[", 
          RowBox[{
           RowBox[{"M", "[", 
            RowBox[{"[", "2", "]"}], "]"}], ",", "5"}], "]"}], ",", 
         RowBox[{"GaussianFilter", "[", 
          RowBox[{
           RowBox[{"M", "[", 
            RowBox[{"[", "3", "]"}], "]"}], ",", "1"}], "]"}]}], "}"}]}], ";",
       "\[IndentingNewLine]", 
      RowBox[{"dim", "=", 
       RowBox[{"Dimensions", "[", "A", "]"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"For", "[", 
       RowBox[{
        RowBox[{"i", "=", "1"}], ",", 
        RowBox[{"i", "<", 
         RowBox[{"dim", "[", 
          RowBox[{"[", "2", "]"}], "]"}]}], ",", 
        RowBox[{"i", " ", "+=", "2"}], ",", 
        RowBox[{
         RowBox[{"A", "[", 
          RowBox[{"[", 
           RowBox[{"3", ",", "i"}], "]"}], "]"}], "=", 
         RowBox[{
          RowBox[{"A", "[", 
           RowBox[{"[", 
            RowBox[{"3", ",", "i"}], "]"}], "]"}], "+", 
          RowBox[{"RandomReal", "[", "]"}]}]}]}], "]"}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"A1", " ", "=", " ", 
       RowBox[{"Table", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{
           RowBox[{"A", "[", 
            RowBox[{"[", 
             RowBox[{"1", ",", "ii"}], "]"}], "]"}], ",", 
           RowBox[{"A", "[", 
            RowBox[{"[", 
             RowBox[{"2", ",", "ii"}], "]"}], "]"}], ",", 
           RowBox[{
            RowBox[{"A", "[", 
             RowBox[{"[", 
              RowBox[{"3", ",", "ii"}], "]"}], "]"}], "*", "z"}]}], "}"}], 
         ",", 
         RowBox[{"{", 
          RowBox[{"ii", ",", "1", ",", 
           RowBox[{"dim", "[", 
            RowBox[{"[", "2", "]"}], "]"}], ",", "1"}], "}"}]}], "]"}]}], ";",
       "\[IndentingNewLine]", 
      RowBox[{"A2", "=", 
       RowBox[{"Table", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{
           RowBox[{"A", "[", 
            RowBox[{"[", 
             RowBox[{"1", ",", "ii"}], "]"}], "]"}], ",", 
           RowBox[{"A", "[", 
            RowBox[{"[", 
             RowBox[{"2", ",", "ii"}], "]"}], "]"}], ",", 
           RowBox[{"A", "[", 
            RowBox[{"[", 
             RowBox[{"3", ",", "ii"}], "]"}], "]"}]}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{"ii", ",", "1", ",", 
           RowBox[{"dim", "[", 
            RowBox[{"[", "2", "]"}], "]"}], ",", "1"}], "}"}]}], "]"}]}], ";",
       "\[IndentingNewLine]", 
      RowBox[{"center", "=", 
       RowBox[{"Mean", "[", "A2", "]"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"i3", "=", " ", 
       RowBox[{"Show", "[", 
        RowBox[{"TableForm", "[", 
         RowBox[{
          RowBox[{"Table", "[", 
           RowBox[{
            RowBox[{"{", 
             RowBox[{"i", ",", 
              RowBox[{"Norm", "[", 
               RowBox[{
                RowBox[{"A2", "[", 
                 RowBox[{"[", "i", "]"}], "]"}], "-", "center"}], "]"}]}], 
             "}"}], ",", 
            RowBox[{"{", 
             RowBox[{"i", ",", 
              RowBox[{"Length", "[", "A2", "]"}]}], "}"}]}], "]"}], ",", 
          RowBox[{"TableHeadings", "->", 
           RowBox[{"{", 
            RowBox[{"None", ",", 
             RowBox[{"{", 
              RowBox[{"\"\<Index\>\"", ",", "\"\<Distance\>\""}], "}"}]}], 
