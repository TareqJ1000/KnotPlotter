 RowBox[{
  RowBox[{
   RowBox[{"KnotJumps", "[", 
    RowBox[{"M_", ",", 
     RowBox[{"z_", ":", "1"}], ",", 
     RowBox[{"LeftShift_", ":", "0"}]}], "]"}], ":=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"A", ",", "dim", ",", "A1", ",", "jumps"}], "}"}], ",", 
     RowBox[{
      RowBox[{"A", "=", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"M", "[", 
          RowBox[{"[", "1", "]"}], "]"}], ",", 
         RowBox[{"M", "[", 
          RowBox[{"[", "2", "]"}], "]"}], ",", 
         RowBox[{"M", "[", 
          RowBox[{"[", "3", "]"}], "]"}]}], "}"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"dim", "=", 
       RowBox[{"Dimensions", "[", "A", "]"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"A1", "=", 
       RowBox[{"Table", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{
           RowBox[{"A", "[", 
            RowBox[{"[", 
             RowBox[{"1", ",", "ii"}], "]"}], "]"}], ",", 
           RowBox[{"A", "[", 
            RowBox[{"[", 
             RowBox[{"2", ",", "ii"}], "]"}], "]"}], ",", 
           RowBox[{
            RowBox[{"A", "[", 
             RowBox[{"[", 
              RowBox[{"3", ",", "ii"}], "]"}], "]"}], "*", "z"}]}], "}"}], 
         ",", 
         RowBox[{"{", 
          RowBox[{"ii", ",", "1", ",", 
           RowBox[{"dim", "[", 
            RowBox[{"[", "2", "]"}], "]"}]}], "}"}]}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"A1", "=", 
       RowBox[{"RotateLeft", "[", 
        RowBox[{"A1", ",", "LeftShift"}], "]"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"A1", "=", 
       RowBox[{"Append", "[", 
        RowBox[{"A1", ",", 
         RowBox[{"A1", "[", 
          RowBox[{"[", "1", "]"}], "]"}]}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"jumps", "=", 
       RowBox[{"Table", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"i", ",", 
           RowBox[{"Norm", "[", 
            RowBox[{
             RowBox[{"A1", "[", 
              RowBox[{"[", 
               RowBox[{"i", "+", "1"}], "]"}], "]"}], "-", 
             RowBox[{"A1", "[", 
              RowBox[{"[", "i", "]"}], "]"}]}], "]"}]}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{"i", ",", 
           RowBox[{
            RowBox[{"Length", "[", "A1", "]"}], "-", "1"}]}], "}"}]}], 
        "]"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"TableForm", "[", 
       RowBox[{"jumps", ",", 
        RowBox[{"TableHeadings", "->", 
         RowBox[{"{", 
          RowBox[{"None", ",", 
           RowBox[{"{", 
            RowBox[{"\"\<Index\>\"", ",", "\"\<Jump\>\""}], "}"}]}], 
          "}"}]}]}], "]"}]}]}], "]"}]}], 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"CleanSingularity", "[", 
    RowBox[{"M_", ",", "inds_"}], "]"}], ":=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", "keep", "}"}], ",", 
