Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"ImportKnot", "[", 
    RowBox[{"M_", ",", "Color_", ",", "z_", ",", 
     RowBox[{"InterpOrder_", ":", "2"}]}], "]"}], ":=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
      "A", ",", "dim", ",", "A1", ",", "A2", ",", "f1", ",", "i0", ",", "i1", 
       ",", "i2"}], "}"}], ",", 
     RowBox[{
      RowBox[{"A", "=", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"GaussianFilter", "[", 
          RowBox[{
           RowBox[{"M", "[", 
            RowBox[{"[", "1", "]"}], "]"}], ",", "5"}], "]"}], ",", 
         RowBox[{"GaussianFilter", "[", 
          RowBox[{
           RowBox[{"M", "[", 
            RowBox[{"[", "2", "]"}], "]"}], ",", "5"}], "]"}], ",", 
         RowBox[{"GaussianFilter", "[", 
          RowBox[{
           RowBox[{"M", "[", 
            RowBox[{"[", "3", "]"}], "]"}], ",", "1"}], "]"}]}], "}"}]}], ";",
       "\[IndentingNewLine]", 
      RowBox[{"dim", "=", 
       RowBox[{"Dimensions", "[", "A", "]"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"For", "[", 
       RowBox[{
        RowBox[{"i", "=", "1"}], ",", 
        RowBox[{"i", "<", 
         RowBox[{"dim", "[", 
          RowBox[{"[", "2", "]"}], "]"}]}], ",", 
        RowBox[{"i", "++"}], ",", 
        RowBox[{
         RowBox[{"A", "[", 
          RowBox[{"[", 
           RowBox[{"3", ",", "i"}], "]"}], "]"}], "=", 
         RowBox[{
          RowBox[{"A", "[", 
           RowBox[{"[", 
            RowBox[{"3", ",", "i"}], "]"}], "]"}], "+", 
          RowBox[{"RandomReal", "[", "]"}]}]}]}], "]"}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"A1", "=", 
       RowBox[{"Table", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{
           RowBox[{"A", "[", 
            RowBox[{"[", 
             RowBox[{"1", ",", "ii"}], "]"}], "]"}], ",", 
           RowBox[{"A", "[", 
            RowBox[{"[", 
             RowBox[{"2", ",", "ii"}], "]"}], "]"}], ",", 
           RowBox[{
            RowBox[{"A", "[", 
             RowBox[{"[", 
              RowBox[{"3", ",", "ii"}], "]"}], "]"}], "*", "z"}]}], "}"}], 
         ",", 
         RowBox[{"{", 
          RowBox[{"ii", ",", "1", ",", 
           RowBox[{"dim", "[", 
            RowBox[{"[", "2", "]"}], "]"}], ",", "1"}], "}"}]}], "]"}]}], ";",
       "\[IndentingNewLine]", 
      RowBox[{"(*", 
       RowBox[{
       "We", " ", "need", " ", "to", " ", "append", " ", "the", " ", "first", 
        " ", "element", " ", "of", " ", "the", " ", "array", " ", "as", " ", 
        "the", " ", "last", " ", "element", " ", "for", " ", "the", " ", 
        "tube", " ", "to", " ", 
        RowBox[{"close", "!"}]}], "*)"}], "\[IndentingNewLine]", 
      RowBox[{"A1", "=", 
       RowBox[{"Append", "[", 
        RowBox[{"A1", ",", 
         RowBox[{"A1", "[", 
          RowBox[{"[", "1", "]"}], "]"}]}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"A2", "=", 
       RowBox[{"Table", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{
           RowBox[{"A", "[", 
            RowBox[{"[", 
             RowBox[{"1", ",", "ii"}], "]"}], "]"}], ",", 
           RowBox[{"A", "[", 
            RowBox[{"[", 
             RowBox[{"2", ",", "ii"}], "]"}], "]"}], ",", 
           RowBox[{"A", "[", 
            RowBox[{"[", 
             RowBox[{"3", ",", "ii"}], "]"}], "]"}]}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{"ii", ",", "1", ",", 
           RowBox[{"dim", "[", 
            RowBox[{"[", "2", "]"}], "]"}], ",", "1"}], "}"}]}], "]"}]}], ";",
       "\[IndentingNewLine]", 
      RowBox[{"f1", "=", 
       RowBox[{"Interpolation", "[", 
        RowBox[{
         RowBox[{"Transpose", "[", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{"Range", "[", 
             RowBox[{"Length", "[", "A1", "]"}], "]"}], ",", "A1"}], "}"}], 
          "]"}], ",", 
         RowBox[{"Method", "->", "\"\<Spline\>\""}], ",", 
         RowBox[{"InterpolationOrder", "->", "InterpOrder"}]}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"i0", "=", 
       RowBox[{"Graphics3D", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"Color", ",", 
           RowBox[{"Tube", "[", "A1", "]"}]}], "}"}], ",", 
         RowBox[{"Boxed", "->", "False"}]}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"i1", "=", 
       RowBox[{
        RowBox[{"ParametricPlot3D", "[", 
         RowBox[{
          RowBox[{"f1", "[", "u", "]"}], ",", 
          RowBox[{"{", 
           RowBox[{"u", ",", "1", ",", 
            RowBox[{"Length", "[", "A1", "]"}]}], "}"}], ",", 
          RowBox[{"ColorFunction", "->", 
           RowBox[{"(", 
            RowBox[{
             RowBox[{"Directive", "[", 
              RowBox[{
               RowBox[{"Opacity", "[", "1", "]"}], ",", "Color"}], "]"}], 
             "&"}], ")"}]}], ",", 
          RowBox[{"ColorFunctionScaling", "->", "False"}], ",", 
          RowBox[{"ImageSize", "->", "Large"}], ",", 
          RowBox[{"ViewPoint", "->", 
           RowBox[{"{", 
            RowBox[{"Pi", ",", 
             RowBox[{"Pi", "/", "2"}], ",", "2"}], "}"}]}], ",", 
          RowBox[{"Boxed", "->", "False"}], ",", 
          RowBox[{"Axes", "->", "False"}], ",", 
          RowBox[{"AspectRatio", "->", "1.0"}], ",", 
          RowBox[{"AxesStyle", "->", 
           RowBox[{"Directive", "[", 
            RowBox[{
             RowBox[{"FontFamily", "->", "\"\<Times New Roman\>\""}], ",", 
             "30", ",", "Black"}], "]"}]}], ",", 
          RowBox[{"Ticks", "->", "None"}]}], "]"}], "/.", " ", 
        RowBox[{
         RowBox[{"Line", "[", 
          RowBox[{"pts_", ",", "rest___"}], "]"}], ":>", 
         RowBox[{"Tube", "[", 
          RowBox[{"pts", ",", "0.5", ",", "rest"}], "]"}]}]}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"i2", "=", 
       RowBox[{"ListPointPlot3D", "[", 
        RowBox[{"A2", ",", 
         RowBox[{"PlotStyle", "->", 
          RowBox[{"{", 
           RowBox[{"{", 
            RowBox[{
             RowBox[{"Darker", "@", "Blue"}], ",", 
             RowBox[{"PointSize", "[", "0.02", "]"}]}], "}"}], "}"}]}], ",", 
         RowBox[{"ViewPoint", "->", 
          RowBox[{"{", 
           RowBox[{"0", ",", 
            RowBox[{"Pi", "/", "2"}], ",", "2"}], "}"}]}], ",", 
         RowBox[{"AspectRatio", "->", "1.0"}], ",", 
         RowBox[{"Boxed", "->", "False"}], ",", 
         RowBox[{"TicksStyle", "->", 
          RowBox[{"Directive", "[", 
           RowBox[{"20", ",", 
            RowBox[{"Opacity", "[", "0", "]"}], ",", 
            RowBox[{"FontOpacity", "->", "0.3"}]}], "]"}]}], ",", 
         RowBox[{"AxesStyle", "->", 
          RowBox[{"Directive", "[", 
           RowBox[{
            RowBox[{"FontFamily", "->", "\"\<Times New Roman\>\""}], ",", 
            "10", ",", "Black"}], "]"}]}], ",", 
         RowBox[{"AxesLabel", "->", 
          RowBox[{"{", 
           RowBox[{"\"\<X\>\"", ",", "\"\<Y\>\"", ",", "\"\<Z\>\""}], "}"}]}],
          ",", 
         RowBox[{"Ticks", "->", "None"}]}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"center", "=", 
       RowBox[{"Mean", "[", "A2", "]"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"Return", "[", 
       RowBox[{"{", 
        RowBox[{"i1", ",", "i2"}], "}"}], "]"}]}]}], "]"}]}], 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"KnotElement", "[", 
   RowBox[{"data_", ",", "pos_", ",", 
    RowBox[{"angle_", ":", "0"}], ",", 
    RowBox[{"scale_", ":", "1"}], ",", 
    RowBox[{"zscale_", ":", "1"}]}], "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"g", ",", "prim"}], "}"}], ",", 
    RowBox[{
     RowBox[{"g", "=", 
      RowBox[{
       RowBox[{"ImportKnot", "[", 
        RowBox[{"data", ",", "Red", ",", "zscale"}], "]"}], "[", 
       RowBox[{"[", "1", "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"prim", "=", 
      RowBox[{"First", "[", "g", "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"Graphics3D", "[", 
      RowBox[{
       RowBox[{"GeometricTransformation", "[", 
        RowBox[{"prim", ",", 
         RowBox[{"Composition", "[", 
          RowBox[{
           RowBox[{"ScalingTransform", "[", 
            RowBox[{"{", 
             RowBox[{"scale", ",", "scale", ",", "scale"}], "}"}], "]"}], ",", 
           RowBox[{"RotationTransform", "[", 
            RowBox[{"angle", ",", 
             RowBox[{"{", 
              RowBox[{"0", ",", "1", ",", "0"}], "}"}]}], "]"}], ",", 
           RowBox[{"TranslationTransform", "[", "pos", "]"}]}], "]"}]}], 
        "]"}], ",", 
       RowBox[{"Boxed", "->", "False"}], ",", 
       RowBox[{"Lighting", "->", "\"\<Neutral\>\""}], ",", " ", 
       RowBox[{"ViewPoint", "\[Rule]", 
        RowBox[{"{", 
         RowBox[{"Pi", ",", 
          RowBox[{"Pi", "/", "2"}], ",", "2"}], "}"}]}]}], "]"}]}]}], 
   "]"}]}]}], "Input",
 CellChangeTimes->{{3.9836311966158504`*^9, 3.9836313004608183`*^9}, {
   3.983631363246163*^9, 3.9836313865929894`*^9}, {3.983632576484787*^9, 
   3.9836325890646544`*^9}, {3.9836326236732316`*^9, 3.98363264159274*^9}, {
   3.9838821662106256`*^9, 3.9838822229860415`*^9}, {3.983882430587112*^9, 
   3.983882431618475*^9}, {3.983883181526066*^9, 3.9838831829528875`*^9}, {
   3.9838834560500174`*^9, 3.9838834952107277`*^9}, {3.983883546725607*^9, 
   3.9838835596492996`*^9}, {3.9838852284309*^9, 3.9838852289117107`*^9}, {
   3.983885497627125*^9, 3.9838855143609147`*^9}, 3.983886002856149*^9, {
   3.983888392651117*^9, 3.9838883969356575`*^9}, {3.9838896034769864`*^9, 
   3.983889606897223*^9}, 3.9838897938343725`*^9, {3.9838898989799366`*^9, 
   3.983889901686311*^9}, {3.983890065267118*^9, 3.9838900676346855`*^9}},
 CellLabel->
